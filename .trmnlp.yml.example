custom_fields:
  spreadsheet_id: "your_google_sheet_id_here"
  quote_index: 1 # column index for quotes (0-based)
  author_index: 2 # column index for authors (0-based)
  hide_title_bar: "No" # Option to hide the bottom title bar ("Yes" or "No")

